# LLM providers — at least one key needed (unless using the free/Ollama preset)
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# Legacy compatibility: an existing lowercase `deepseek` env var is also accepted
OPENAI_API_KEY=

# Optional: Telegram bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Optional: ElevenLabs TTS (if using elevenlabs backend instead of gemini)
ELEVENLABS_API_KEY=

# Optional: Ollama server URL (default: http://localhost:11434)
# For Docker: use http://host.docker.internal:11434 to reach host Ollama
# OLLAMA_BASE_URL=

# Optional: Demo mode — read-only dashboard with rate-limited chat widget
# NEXUS_DEMO_MODE=1

# Optional: allow remote access to /setup and /settings when not using localhost
# NEXUS_ADMIN_TOKEN=change-me

# Optional: re-enable /setup after config.yaml already exists
# NEXUS_ALLOW_SETUP_RESET=1
