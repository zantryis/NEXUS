# Required: at least one LLM provider
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: additional LLM providers
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Optional: Telegram bot (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Optional: ElevenLabs TTS (if using elevenlabs backend instead of gemini)
ELEVENLABS_API_KEY=
